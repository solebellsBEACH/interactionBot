{
  "name": "interaction-bot",
  "version": "1.0.0",
  "description": "Script Playwright que abre o LinkedIn com interface gráfica.",
  "main": "src/main.ts",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "ts-node src/interactor/main.ts",
    "open:linkedin": "npx ts-node src/interactor/main.ts",
    "worker": "ts-node src/interactor/worker.ts",
    "test:phase1": "node --test -r ts-node/register src/interactor/worker/worker-job.test.ts src/interactor/shared/user-profile.test.ts",
    "test:phase4": "node --test -r ts-node/register src/interactor/worker/worker-job.test.ts src/interactor/shared/user-profile.test.ts src/interactor/shared/utils/user-data-dir.test.ts",
    "install:chrome": "npx playwright install chrome",
    "install:browsers": "npx playwright install chromium",
    "test": "node scripts/test-functions.mjs",
    "test:playwright": "playwright test",
    "test:ui": "playwright test --ui --headed",
    "build:web": "npm run build --workspace=packages/web"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "bullmq": "^5.71.0",
    "discord.js": "^14.16.3",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.0",
    "openai": "^6.27.0",
    "playwright": "1.48.2",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@playwright/test": "1.48.2",
    "@types/node": "^25.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
